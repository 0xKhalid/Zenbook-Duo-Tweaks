AUTHOR="Khalid M AlAwadhi <khalid@remal.io>"
PROJECT_URL="https://github.com/0xKhalid/Zenbook-Duo-Tweaks"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TWEAKS_DIR="${REPO_DIR}/tweaks"

#================================================================
#  Colors & Output Helpers
#================================================================

if [[ -t 1 ]]; then
	C_RESET='\033[0m'
	C_BOLD='\033[1m'
	C_DIM='\033[2m'
	C_RED='\033[1;31m'
	C_GREEN='\033[1;32m'
	C_YELLOW='\033[1;33m'
	C_BLUE='\033[1;34m'
	C_CYAN='\033[1;36m'
	C_WHITE='\033[1;37m'
	C_BG_CYAN='\033[46m'
	C_BG_RED='\033[41m'
	C_BG_GREEN='\033[42m'
	C_BLACK='\033[30m'
else
	C_RESET='' C_BOLD='' C_DIM='' C_RED='' C_GREEN=''
	C_YELLOW='' C_BLUE='' C_CYAN='' C_WHITE=''
	C_BG_CYAN='' C_BG_RED='' C_BG_GREEN='' C_BLACK=''
fi

success() { echo -e "${C_GREEN}  [+]${C_RESET} $*"; }
warn()    { echo -e "${C_YELLOW}  [!]${C_RESET} $*"; }
error()   { echo -e "${C_RED}  [-]${C_RESET} $*" >&2; }

#================================================================
#  System Info (for about screen)
#================================================================

get_system_info()
{
	SYS_OS=$(cat /etc/fedora-release 2>/dev/null || echo "Unknown")
	SYS_KERNEL=$(uname -r 2>/dev/null || echo "Unknown")
	SYS_DESKTOP="${XDG_CURRENT_DESKTOP:-Unknown}"
	SYS_SESSION="${XDG_SESSION_TYPE:-Unknown}"
}

